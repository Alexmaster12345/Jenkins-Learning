pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps {
                script {
                    def nodeInstalled = sh(script: 'which node || true', returnStdout: true).trim()
                    if (nodeInstalled) {
                        sh '''
                            ls -la
                            npm --version
                            npm install
                            npm run build
                            ls -la
                        '''
                    }
                }
            }
        }

        stage('Run tests') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        sh 'echo Running unit tests...'
                    }
                }
                stage('Test') {
                    steps {
                        sh 'test -f build/index.html'
                    }
                }
                stage('Integration Tests') {
                    steps {
                        sh 'echo Running integration tests...'
                    }
                }
            }
        }

    }
}