pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps {
                script {
                    def nodeInstalled = sh(script: 'which node || true', returnStdout: true).trim()
                    if (nodeInstalled) {
                        sh '''
                            ls -la
                            npm --version
                            npm install
                            npm run build
                            ls -la
                        '''
                    }
                }
            }
        }

        stage('Test') {
            steps {
                sh 'test -f build/index.html'
            }
        }
    }
}